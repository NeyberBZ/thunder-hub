---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { supabaseServer } from "../../../lib/supabase-server";

const id = Astro.params.id;

const { data: candidato, error } = await supabaseServer
  .from("candidatos")
  .select("*")
  .eq("id", id)
  .single();

if (error) {
  throw new Error("Candidato no encontrado");
}

const { data: timeline } = await supabaseServer
  .from("candidato_seguimiento")
  .select("*")
  .eq("candidato_id", id)
  .order("created_at", {
    ascending: false,
  });
---

<AdminLayout title={`Candidato: ${candidato.nombres} ${candidato.apellidos}`}>
  <h1 class="text-3xl font-bold mb-6">Detalle del Candidato</h1>

  <div class="bg-white rounded-xl shadow p-6 mb-6">
    <h2 class="text-xl font-semibold mb-2">Datos Personales</h2>
    <p><strong>Nombre:</strong> {candidato.nombres} {candidato.apellidos}</p>
    <p><strong>Teléfono:</strong> {candidato.telefono}</p>
    <p><strong>Email:</strong> {candidato.email}</p>
    <p><strong>DNI:</strong> {candidato.dni}</p>
    <p><strong>Edad:</strong> {candidato.edad}</p>
    <p><strong>Distrito:</strong> {candidato.distrito}</p>
    <p><strong>Puesto:</strong> {candidato.puesto_postular}</p>
    <p><strong>Licencia:</strong> {candidato.licencia_conducir}</p>
    <p><strong>Categoría:</strong> {candidato.categoria_licencia}</p>
    <p><strong>Años de experiencia:</strong> {candidato.experiencia_anios}</p>
    <p><strong>Cambiar Estado:</strong></p>
    <p class="mb-3">
      <strong>Estado actual:</strong>

      <span
        id="estado-badge"
        class="px-2 py-1 rounded bg-blue-100 text-blue-700"
      >
        {candidato.estado}
      </span>
    </p>
    <select
      id="estado-select"
      class="border rounded p-2 mb-3"
      value={candidato.estado}
    >
      <option value="Nuevo">Nuevo</option>
      <option value="Contactado">Contactado</option>
      <option value="Entrevista">Entrevista</option>
      <option value="Evaluación">Evaluación</option>
      <option value="Contratado">Contratado</option>
      <option value="Descartado">Descartado</option>
    </select>
    <p>
      <strong>Fecha de contacto:</strong>
      {
        candidato.fecha_contacto
          ? new Date(candidato.fecha_contacto).toLocaleDateString()
          : "No registrado"
      }
    </p>
  </div>

  <div class="bg-white rounded-xl shadow p-6">
    <h2 class="text-xl font-semibold mb-2">CV</h2>
    <div class="bg-white rounded-xl shadow p-6">
      <div class="flex justify-between mb-4">
        <h2 class="text-xl font-semibold">Curriculum Vitae</h2>

        <a href={candidato.cv_url} target="_blank" class="text-blue-600">
          Abrir PDF
        </a>
      </div>

      <iframe src={candidato.cv_url} class="w-full h-225 rounded-lg border"
      ></iframe>
    </div>

    <div class="bg-white rounded-xl shadow p-6 mt-6">
      <h2 class="text-xl font-semibold mb-6">Seguimiento</h2>

      <div id="timeline-container" class="space-y-6">
        {
          timeline?.map((item) => (
            <div class="flex gap-4">
              <div
                class={`w-3 h-3 rounded-full mt-2 ${
                  item.tipo === "LLAMADA"
                    ? "bg-blue-500"
                    : item.tipo === "ENTREVISTA"
                    ? "bg-yellow-500"
                    : item.tipo === "EVALUACION"
                    ? "bg-purple-500"
                    : item.tipo === "CONTRATACION"
                    ? "bg-green-500"
                    : "bg-gray-500"
                }`}
              />

              <div>
                <div class="font-semibold">{item.tipo}</div>

                <div class="text-gray-600">{item.comentario}</div>

                <div class="text-sm text-gray-400">
                  {new Date(item.created_at).toLocaleString()}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="bg-white rounded-xl shadow p-6 mt-6">
      <h2 class="text-xl font-semibold mb-4">Agregar Seguimiento</h2>

      <select id="tipo-evento" class="border rounded p-2 w-full mb-3">
        <option value="LLAMADA"> LLAMADA </option>

        <option value="ENTREVISTA"> ENTREVISTA </option>

        <option value="EVALUACION"> EVALUACION </option>

        <option value="CONTRATACION"> CONTRATACION </option>
      </select>

      <textarea
        id="comentario-evento"
        class="border rounded p-3 w-full"
        rows="4"
      >
      </textarea>

      <button
        id="guardar-evento"
        class="bg-slate-900 text-white px-4 py-2 rounded mt-3"
      >
        Guardar Evento
      </button>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow p-6 mt-6">
    <h2 class="text-xl font-semibold mb-2">Observaciones</h2>
    <textarea
      id="observaciones-textarea"
      class="w-full border rounded p-3"
      rows="4"
      placeholder="Agregar observaciones aquí..."
      >{candidato.observaciones || ""}</textarea
    >
    <button
      id="save-observacion"
      class="mt-3 bg-slate-900 text-white px-4 py-2 rounded"
    >
      Guardar Observación
    </button>
  </div>

    <script define:vars={{ id }} type="module">
      const CANDIDATO_ID = id;

      const estadoSelect = document.getElementById("estado-select");

      if (estadoSelect) {
        estadoSelect.addEventListener("change", async (e) => {
          const newEstado = e.target.value;

          const res = await fetch(`/api/candidatos/${CANDIDATO_ID}/update`, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({
              estado: newEstado,
            }),
          });

          if (res.ok) {
            const estadoBadge =
              document.getElementById(
                "estado-badge"
              );

            estadoBadge.textContent =
              newEstado;
          }
        });
      }

      const saveBtn = document.getElementById("save-observacion");

      const obsTextarea = document.getElementById("observaciones-textarea");

      if (saveBtn && obsTextarea) {
        saveBtn.addEventListener("click", async () => {
          const observaciones = obsTextarea.value;

          const res = await fetch(`/api/candidatos/${CANDIDATO_ID}/update`, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({
              observaciones,
            }),
          });

          if (res.ok) {
            alert("Observación guardada");
          }
        });
      }

      const eventoBtn = document.getElementById("guardar-evento");

      eventoBtn?.addEventListener("click", async () => {
        const tipo = document.getElementById("tipo-evento").value;

        const comentario = document.getElementById("comentario-evento").value;

        if (!comentario.trim()) {
          alert("Debe ingresar un comentario");
          return;
        }

        const response = await fetch(
          `/api/candidatos/${CANDIDATO_ID}/timeline`,
          {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({
              tipo,
              comentario,
            }),
          },
        );

        if (response.ok) {

          const payload =
            await response.json();

          const item =
            payload.data;

          const colorMap = {
            LLAMADA: "bg-blue-500",
            ENTREVISTA: "bg-yellow-500",
            EVALUACION: "bg-purple-500",
            CONTRATACION: "bg-green-500"
          };

          const color =
            colorMap[item.tipo] ??
            "bg-gray-500";

          const timelineContainer =
            document.getElementById(
              "timeline-container"
            );

          const nuevoEvento =
            document.createElement("div");

          nuevoEvento.className =
            "flex gap-4";

          nuevoEvento.innerHTML = `
            <div class="w-3 h-3 ${color} rounded-full mt-2"></div>

            <div>

              <div class="font-semibold">
                ${item.tipo}
              </div>

              <div class="text-gray-600">
                ${item.comentario}
              </div>

              <div class="text-sm text-gray-400">
                ${new Date(item.created_at).toLocaleString()}
              </div>

            </div>
          `;

          if (timelineContainer) {
            timelineContainer.prepend(
              nuevoEvento
            );
          }

          document.getElementById(
            "comentario-evento"
          ).value = "";

          document.getElementById(
            "tipo-evento"
          ).value = "LLAMADA";

        }
      });
    </script>

</AdminLayout>
